DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

PORT=3001

# Mínimo 32 caracteres — gere com: openssl rand -base64 32
JWT_SECRET="troque-por-um-segredo-longo-e-aleatorio-com-32-chars-minimo"
JWT_EXPIRES_IN=7d

# Opcional: cria/atualiza admin no seed (npm run db:seed)
ADMIN_EMAIL=admin@paroquia.local
ADMIN_PASSWORD=senha-forte-aqui
ADMIN_NOME=Coordenação Geral
